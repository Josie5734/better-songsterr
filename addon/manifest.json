{
  "manifest_version": 3,

  "name": "Better Songsterr",
  "version": "1.1",

  "description": "Small improvements to the user experience of Songsterr.",

  "icons": {
    "48": "icons/48x48.png",
    "96": "icons/96x96.png"
  },

  "action": {
    "default_title": "Better Songsterr",
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://*.songsterr.com/*"],
      "js": ["content.js"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "BetterSongsterr@github.com/Josie5734",

      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": ["storage"]
}
